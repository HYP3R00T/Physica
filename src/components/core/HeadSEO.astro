---
import type { ImageMetadata } from "astro";
import { ClientRouter } from "astro:transitions";
import { getImage } from "astro:assets";

import "@/styles/global.css";

import { SITE } from "@/config";

// Props with fallbacks from SITE config
const {
  title = SITE.title,
  description = SITE.description,
  image = SITE.image, // string | imported asset | content collection image()
  imageAlt = SITE.imageAlt,
  contentType = SITE.contentType,
  noIndex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url);
// Prefer configured site URL when Astro.site isn't available (e.g., in dev)
const siteUrl = Astro.site ?? SITE.website ?? "http://127.0.0.1:4321";

const robotsValue = noIndex ? "noindex, nofollow" : "index, follow";

const isImageMetadata = (value: unknown): value is ImageMetadata =>
  typeof value === "object" &&
  value !== null &&
  "src" in value &&
  "width" in value &&
  "height" in value &&
  "format" in value;

const resolveOgImageUrl = async (source: typeof image): Promise<string> => {
  if (typeof source === "string" && source.startsWith("http")) {
    return source;
  }

  if (isImageMetadata(source)) {
    try {
      const { src } = await getImage({
        src: source,
        width: 1200,
        height: 630,
        format: "jpeg",
        quality: 70,
      });
      return new URL(src, siteUrl).toString();
    } catch {
      return new URL(source.src, siteUrl).toString();
    }
  }

  if (typeof source === "string") {
    try {
      const { src } = await getImage({
        src: source,
        width: 1200,
        height: 630,
        format: "jpeg",
        quality: 70,
      });
      return new URL(src, siteUrl).toString();
    } catch {
      // Fallback: just prefix with siteUrl if optimization fails
      return new URL(source, siteUrl).toString();
    }
  }

  return String(source);
};

// Generate a fully qualified OG image URL
const ogImageUrl = await resolveOgImageUrl(image);
---

<!-- Global Metadata -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta charset="UTF-8" />
<meta name="robots" content={robotsValue} />
<meta name="googlebot" content={robotsValue} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Favicon -->
<link rel="apple-touch-icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- OpenGraph Meta Tags -->
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content={contentType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:alt" content={imageAlt} />

<!-- Twitter Card Meta Tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={imageAlt} />
<meta name="twitter:creator" content={SITE.twitterHandle} />

<ClientRouter />
