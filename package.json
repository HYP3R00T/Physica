{
  "name": "physica",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm wasm:build && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "wasm:setup": "cargo install wasm-pack",
    "wasm:build": "wasm-pack build engine/physica-wasm --target web --out-dir ../../src/wasm/pkg --out-name physica_wasm --release",
    "wasm:build:dev": "wasm-pack build engine/physica-wasm --target web --out-dir ../../src/wasm/pkg --out-name physica_wasm"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/react": "^4.4.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "astro": "^5.18.0",
    "astro-icon": "^1.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0"
  }
}
